generator client {
  provider = "prisma-client"
  output = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}   

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String  
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
}

model Products {
  id       String   @id @default(uuid())
  name   String    
  size   String?
  description   String?
  createdAt DateTime  @default(now()) @db.Timestamptz(6)
}